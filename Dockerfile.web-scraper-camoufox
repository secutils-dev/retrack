FROM python:3.14-slim-trixie@sha256:aee3b1c52ce756c42ee4ad90437ae49d87fa87fc2f09c17895f098b67f081a8d
EXPOSE 7777

ENV CAMOUFOX_PORT=7777
ENV CAMOUFOX_WS_PATH=camoufox
ENV CAMOUFOX_USE_MAIN_WORLD=true
ENV CAMOUFOX_HEADLESS=true

WORKDIR /app

# Layer 1: OS deps (Firefox runtime libraries + init). No git/curl needed: the
# camoufox library and its browser builds are fetched over HTTP from PyPI and the
# daijro release repo via `requests`, and playwright-python now ships as a proper
# PyPI wheel (no git clone of a release branch).
RUN set -x \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
        libgtk-3-0 libx11-xcb1 libasound2 dumb-init \
    && rm -rf /var/lib/apt/lists/*

# Layer 2: Camoufox install + patch + fetch
#
# We use the OFFICIAL `camoufox` package (daijro) rather than the `cloverlabs-camoufox`
# fork. The fork's `launchServer.js` still does `require(${cwd}/lib/browserServerImpl.js)`,
# a driver internal that playwright 1.60 removed, so it crash-loops on playwright >= 1.60.
# The official package resolves Playwright through the driver's public `index.js` entrypoint
# and calls the public `firefox.launchServer()` API, which is stable across 1.60/1.61 — so it
# works on playwright 1.61 despite its conservative `playwright<1.61` pin. We install camoufox
# first (which pulls playwright 1.60.0) and then force playwright to 1.61.0 to match the rest
# of the stack (scraper / webui playwright-core, e2e @playwright/test); pip prints a harmless
# dependency-conflict warning and proceeds.
#
# CAMOUFOX_VERSION is the Firefox version to pin (NOT the build label). The build label is
# resolved from the synced repo cache below rather than hardcoded, because daijro has in the
# past tagged the *same* version with a *different* build label per architecture.
#
# Three upstream gotchas, all guarded below so they fail the build loudly instead of silently
# shipping a browser-less image that crash-loops at runtime with `CamoufoxNotInstalled`:
#   1. `camoufox fetch <id>` exits 0 even when the build is absent from the cache.
#   2. The build label can be architecture-specific, so we resolve it from the platform-filtered
#      cache rather than hardcoding it.
#   3. The official package's multiversion installer lays the browser down under
#      `browsers/official/<version>-<build>-<sha8>` — i.e. with an 8-char sha suffix appended to
#      the `<version>-<build>` id — and only treats it as installed once a `version.json` marker
#      exists in that folder. So we locate the install by `<version>-<build>` *prefix* and assert
#      its `version.json`, instead of matching the bare id (which never matches the sha-suffixed dir).
ARG CAMOUFOX_VERSION=152.0.4
RUN set -eux \
    && pip install camoufox==0.5.4 \
    && pip install playwright==1.61.0 \
    && sed -i 's/fontconfigs/fontconfig/g' /usr/local/lib/python3.14/site-packages/camoufox/utils.py \
    && python -m camoufox sync \
    && CAMOUFOX_BUILD="$(python -c "import json; d=json.load(open('/root/.cache/camoufox/repo_cache.json')); print(next((x['version']+'-'+x['build'] for r in d['repos'] if r['name']=='Official' for x in r['versions'] if x['version']=='${CAMOUFOX_VERSION}'), ''))")" \
    && test -n "${CAMOUFOX_BUILD}" \
    && echo "Resolved Camoufox build for ${CAMOUFOX_VERSION}: ${CAMOUFOX_BUILD}" \
    && echo y | python -m camoufox fetch "official/${CAMOUFOX_BUILD}" \
    && CAMOUFOX_DIR="$(find /root/.cache/camoufox/browsers/official -mindepth 1 -maxdepth 1 -type d -name "${CAMOUFOX_BUILD}*" 2>/dev/null | head -1)" \
    && test -n "${CAMOUFOX_DIR}" \
    && test -f "${CAMOUFOX_DIR}/version.json" \
    && echo "Installed Camoufox browser at: ${CAMOUFOX_DIR}"

# Copy the custom runner that allows specifying different options.
COPY ./dev/docker/camoufox_launcher.py /app/

ENTRYPOINT ["/usr/bin/dumb-init", "--"]
CMD ["python", "/app/camoufox_launcher.py"]
