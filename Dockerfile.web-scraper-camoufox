FROM python:3.14-slim-trixie@sha256:aee3b1c52ce756c42ee4ad90437ae49d87fa87fc2f09c17895f098b67f081a8d
EXPOSE 7777

ENV CAMOUFOX_PORT=7777
ENV CAMOUFOX_WS_PATH=camoufox
ENV CAMOUFOX_USE_MAIN_WORLD=true
ENV CAMOUFOX_HEADLESS=true

WORKDIR /app

# Layer 1: OS deps
RUN set -x \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
        libgtk-3-0 libx11-xcb1 libasound2 dumb-init \
        git curl \
    && rm -rf /var/lib/apt/lists/*

# Layer 2: Camoufox install + patch + fetch
#
# CAMOUFOX_BUILD is the camoufox build ID to fetch. Note this is the *asset* build
# label, which differs from the upstream git tag: daijro release `v150.0.2-beta.25`
# ships its Linux asset as `camoufox-150.0.2-alpha.25-lin.arm64.zip`, so the build
# ID camoufox understands is `150.0.2-alpha.25` (not `-beta.25`).
#
# Two upstream gotchas make this pin fragile, hence the explicit verification below:
#   1. `camoufox fetch <id>` exits 0 even when the build is absent from the synced
#      repo cache, silently baking a browser-less image that crash-loops at runtime
#      with `CamoufoxNotInstalled`.
#   2. `camoufox sync` dedups available builds by their *build label* alone
#      (`seen_builds`), so when two daijro releases share a label (e.g. both
#      `146.0.1` and `150.0.2` ship `alpha.25`), only the newest survives in the
#      cache and the older `<version>-<label>` id stops resolving. This is why the
#      previous `official/146.0.1-alpha.25` pin broke once `v150.0.2` was published.
# The `test` guards turn either failure into a hard build error instead of a
# runtime crash loop.
ARG CAMOUFOX_BUILD=150.0.2-alpha.25
RUN set -x \
    && pip install cloverlabs-camoufox==0.5.5 \
    && pip install "git+https://github.com/microsoft/playwright-python.git@release-1.59" \
    && sed -i 's/fontconfigs/fontconfig/g' /usr/local/lib/python3.14/site-packages/camoufox/utils.py \
    && python -m camoufox sync \
    && echo y | python -m camoufox fetch "official/${CAMOUFOX_BUILD}" \
    && test -d "/root/.cache/camoufox/browsers/official/${CAMOUFOX_BUILD}" \
    && test -n "$(ls -A "/root/.cache/camoufox/browsers/official/${CAMOUFOX_BUILD}")"

# Layer 3: Remove build-only packages
RUN apt-get purge -y --auto-remove git curl \
    && rm -rf /var/lib/apt/lists/*

# Copy the custom runner that allows specifying different options.
COPY ./dev/docker/camoufox_launcher.py /app/

ENTRYPOINT ["/usr/bin/dumb-init", "--"]
CMD ["python", "/app/camoufox_launcher.py"]
