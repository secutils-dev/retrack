{
  "db_name": "PostgreSQL",
  "query": "\nSELECT d.id, d.tracker_id, d.data, d.created_at\nFROM unnest($1::uuid[]) AS t(tracker_id)\nCROSS JOIN LATERAL (\n    SELECT *\n    FROM trackers_data td\n    WHERE td.tracker_id = t.tracker_id\n    ORDER BY td.created_at DESC\n    LIMIT $2\n) d\n            ",
