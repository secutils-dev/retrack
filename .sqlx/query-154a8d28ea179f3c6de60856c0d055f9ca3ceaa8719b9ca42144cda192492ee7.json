{
  "db_name": "PostgreSQL",
  "query": "SELECT t.id AS \"id!\", t.name AS \"name!\", t.enabled AS \"enabled!\", t.config AS \"config!\", t.tags AS \"tags!\", t.created_at AS \"created_at!\", t.updated_at AS \"updated_at!\", t.job_id, t.job_needed AS \"job_needed!\", to_timestamp(sj.next_tick) AS scheduled_at, to_timestamp(sj.last_tick) AS last_ran_at FROM trackers t LEFT JOIN scheduler_jobs sj ON t.job_id = sj.id WHERE t.tags @> $1 AND ($2::text IS NULL OR t.name ILIKE ('%' || $2 || '%') ESCAPE '\\') ORDER BY t.updated_at ASC NULLS LAST, t.id ASC LIMIT $3 OFFSET $4",
