{
  "name": "retrack-web-scraper",
  "private": true,
  "author": {
    "name": "Aleh Zasypkin",
    "email": "dev@retrack.dev"
  },
  "version": "0.0.1",
  "engines": {
    "node": "24.x"
  },
  "type": "module",
  "main": "dist/src/index.js",
  "scripts": {
    "prebuild": "eslint . && rm -rf dist",
    "build": "tsc --project ./",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "watch": "NODE_OPTIONS=--import=./register.js node --env-file-if-exists=../../.env --watch src/index.ts",
    "test": "NODE_OPTIONS=--import=./register.js NODE_NO_WARNINGS=1 node --experimental-test-module-mocks --test ./src/tests.ts",
    "test:watch": "NODE_OPTIONS=--import=./register.js NODE_NO_WARNINGS=1 node --experimental-test-module-mocks --test --watch ./src/tests.ts"
  },
  "overrides": {
    "@types/node": "^24.13.3"
  },
  "dependencies": {
    "@fastify/compress": "^9.1.0",
    "fastify": "^5.10.0",
    "playwright-core": "1.61.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.3",
    "@types/ws": "^8.18.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.9.5",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "ws": "^8.21.1"
  }
}
